// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "preview_tabs": {
    "enabled": false
  },
  "text_rendering_mode": "platform_default",
  "colorize_brackets": true,
  "agent": {
    "use_modifier_to_send": true,
    "play_sound_when_agent_done": false,
    "notify_when_agent_waiting": "all_screens",
    "always_allow_tool_actions": true,
    "model_parameters": []
  },
  "buffer_font_weight": 400.0,
  "buffer_line_height": "comfortable",
  "diagnostics": {
    "inline": {
      "update_debounce_ms": 50,
      "enabled": true
    }
  },
  "completions": {
    "lsp_fetch_timeout_ms": 200
  },
  "edit_predictions": {
    "enabled_in_text_threads": true,
    "mode": "eager",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null
    }
  },
  "autosave": "on_focus_change",
  "telemetry": {
    "metrics": true
  },
  "load_direnv": "direct",
  "ui_font_size": 18.0,
  "buffer_font_size": 14.0,
  "buffer_font_features": {
    "calt": true,
    "cv01": 7
  },
  "scrollbar": {
    "show": "auto"
  },
  "terminal": {
    "font_features": {
      "calt": true,
      "cv01": 7
    }
  },
  "show_wrap_guides": true,
  "wrap_guides": [80, 100, 120],
  "format_on_save": "off",
  "minimap": {
    "show": "always",
    "current_line_highlight": "all",
    "thumb": "hover"
  },
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "show_background": false,
    "edit_debounce_ms": 200,
    "scroll_debounce_ms": 50
  },
  "indent_guides": {
    "coloring": "indent_aware",
    "background_coloring": "disabled"
  },
  "lsp": {
    "metals": {
      "binary": {
        "path": "/home/lucas/.local/share/coursier/bin/metals",
        "arguments": ["-Dmetals.http=on", "-Dmetals.startMcpServer=true"]
      },
      "initialization_options": {
        "isHttpEnabled": true
      },
      "settings": {
        "inlayHints": {
          "inferredTypes": {
            "enable": true
          },
          "implicitArguments": {
            "enable": true
          },
          "implicitConversions": {
            "enable": true
          },
          "typeParameters": {
            "enable": true
          },
          "hintsInPatternMatch": {
            "enable": true
          },
          "startMcpServer": true,
          "mcpClient": "claude",
        },
        "showImplicitArguments": true,
        "showInferredType": true
      }
    }
  },
  "languages": {
    "Scala": {
      "show_whitespaces": "trailing",
      "ensure_final_newline_on_save": false,
      "remove_trailing_whitespace_on_save": false,
      "auto_indent": false,
      "auto_indent_on_paste": false,
      "inlay_hints": {
        "show_background": false
      },
      "completions": {
        "lsp_fetch_timeout_ms": 200
      },
      "indent_guides": {
        "coloring": "indent_aware",
        "background_coloring": "disabled"
      },
      "language_servers": ["metals"],
      "tab_size": 2,
      "preferred_line_length": 100,
      "format_on_save": "off"
    }
  }
}

