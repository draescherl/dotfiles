# Read `man 5 sway` for a complete reference.

# Theme and font
include ./themes/catppuccin-frappe
seat seat0 xcursor_theme Adwaita 24

# Navigation
set $mod Mod4
set $left h
set $down j
set $up k
set $right l

# AZERTY number row
set $one ampersand
set $two eacute
set $three quotedbl
set $four apostrophe
set $five parenleft
set $six minus
set $seven egrave
set $eight underscore
set $nine ccedilla
set $ten agrave

# Core bindings
set $files nautilus -w
set $menu fuzzel
set $term alacritty
set $clipboard cliphist list | fuzzel --dmenu | cliphist decode | wl-copy && wtype -M ctrl -M shift -k v -m ctrl
set $suspend swaylock -f && sleep 2 && systemctl suspend
set $lock swaylock -f
set $notifications swaync-client -t -sw
set $audioUp pactl set-sink-volume @DEFAULT_SINK@ +5%
set $audioDown pactl set-sink-volume @DEFAULT_SINK@ -5%
set $audioMute pactl set-sink-mute @DEFAULT_SINK@ toggle
set $micMute pactl set-source-mute @DEFAULT_SOURCE@ toggle
set $brightUp brightnessctl set 20%-
set $brightDown brightnessctl set 20%+
set $screenshot grimshot --notify --cursor savecopy area

# Includes
include ./bar.conf
include ./input.conf
include ./output.conf
include ./idle.conf
include ./keybinds.conf
include ./swayfx.conf
include /etc/sway/config.d/*

# Autostart
exec_always swaybg --image ~/wallpapers/current --mode fill
exec swaync
exec wl-paste --type text --watch cliphist store
exec wl-paste --type image --watch cliphist store
exec dbus-update-activation-environment --systemd --all
exec nm-applet --indicator
exec lxpolkit
