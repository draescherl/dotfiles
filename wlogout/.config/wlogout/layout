{
    "label" : "lock",
    "action" : "hyprlock",
    "text" : "[l]ock",
    "keybind" : "l"
}
{
    "label" : "sleep",
    "action" : "hyprlock && sleep 2 && systemctl suspend",
    "text" : "[s]leep",
    "keybind" : "s"
}
{
    "label" : "logout",
    "action" : "loginctl terminate-user $USER",
    "text" : "[e]xit",
    "keybind" : "e"
}
{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "[r]eboot",
    "keybind" : "r"
}
{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "text" : "[x] shutdown",
    "keybind" : "x"
}
