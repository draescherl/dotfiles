include "./common/base.kdl"

binds {
    // --- Menu / clipboard / session ----------------------------------------
    Mod+M { spawn "fuzzel"; }
    Mod+Shift+V { spawn-sh "cliphist list | fuzzel --dmenu | cliphist decode | wl-copy && wtype -M ctrl -M shift -k v -m ctrl"; }
    Mod+O { spawn "wleave"; }

    // --- Waybar ------------------------------------------------------------
    Mod+Y { spawn "pkill" "-SIGUSR1" "waybar"; }        // hide waybar
    Mod+Shift+Y { spawn "pkill" "-SIGUSR2" "waybar"; }  // reload waybar

    // --- Wallpaper ---------------------------------------------------------
    Mod+Shift+W { spawn-sh "swaybg --image ~/wallpapers/current --mode fill & sleep 0.3; pkill -xo swaybg"; }

    // --- Audio -------------------------------------------------------------
    XF86AudioRaiseVolume { spawn "pactl" "set-sink-volume" "@DEFAULT_SINK@" "+5%"; }
    XF86AudioLowerVolume { spawn "pactl" "set-sink-volume" "@DEFAULT_SINK@" "-5%"; }
    XF86AudioMute        { spawn "pactl" "set-sink-mute" "@DEFAULT_SINK@" "toggle"; }
    Shift+XF86AudioMute  { spawn "pactl" "set-source-mute" "@DEFAULT_SOURCE@" "toggle"; }
    XF86AudioMicMute     { spawn "pactl" "set-source-mute" "@DEFAULT_SOURCE@" "toggle"; }

    // --- Brightness --------------------------------------------------------
    XF86MonBrightnessDown { spawn "brightnessctl" "set" "20%-"; }
    XF86MonBrightnessUp   { spawn "brightnessctl" "set" "20%+"; }
}

spawn-sh-at-startup "swaybg --image ~/wallpapers/current --mode fill"
spawn-at-startup "blueman-applet"
spawn-at-startup "nm-applet" "--indicator"
spawn-at-startup "waybar"
spawn-at-startup "wl-paste" "--type" "image" "--watch" "cliphist" "store"
spawn-at-startup "wl-paste" "--type" "text" "--watch" "cliphist" "store"
spawn-at-startup "xwayland-satellite"

include "noctalia.kdl"
